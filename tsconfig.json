{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"baseUrl": ".",
		"declaration": true,
		"emitDecoratorMetadata": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"lib": [
			"ESNext",
			"dom"
		],
		"module": "es6",
		"moduleResolution": "node",
		"noImplicitAny": false,
		"outDir": "dist",
		"resolveJsonModule": true,
		"rootDir": "./src",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es6",
		"types": [
			"node",
			"wechat-miniprogram"
		]
	},
	"exclude": [
		"dist"
	],
	"ts-node": {
		"files": true,
		"transpileOnly": true
	}
}