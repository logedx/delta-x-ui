<view style="{{ style }}" class="dx-synopsis dx-class class">
	<view class="thumbnail">
		<dx-avatar
			size="{{ size }}"
			src="{{ thumbnail }}"
			square="{{ square }}"
			dx-class="avatar"
		/>
	</view>

	<view class="content">
		<text class="title">{{ title }}</text>

		<view class="exhibit">
			<slot />
		</view>
	</view>
</view>
